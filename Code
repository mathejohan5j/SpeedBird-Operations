@bot.event
async def on_message(message: discord.Message):
    if message.author.bot or not message.guild:
        return
    if not _contains_slur(message.content):
        return

    # Delete the offending message first
    try:
        await message.delete()
    except (discord.NotFound, discord.Forbidden):
        pass

    # DM the user an appeal notice before the ban removes shared guild
    appeal_embed = discord.Embed(color=BRAND_COLOR)
    appeal_embed.description = (
        f'## You have been banned from British Airways Virtual PF\n\n'
        f'> Your account has been **permanently banned** from **British Airways Virtual PF** '
        f'for sending a message that contained hate speech or a racial/discriminatory slur.\n\n'
        f'We operate a **zero-tolerance policy** on hate speech. This action was taken automatically.\n\n'
        f'**To appeal your ban**, please contact a Senior Staff member through an alternate account '
        f'or reach out via the BA Virtual community channels.\n\n'
        f'-# *Attempting to rejoin without completing an appeal will result in an immediate re-ban.*\n\n'
        f'-# © British Airways Virtual PF. All rights reserved.'
    )
    try:
        await message.author.send(embed=appeal_embed)
    except (discord.Forbidden, discord.HTTPException):
        pass

    # Execute the ban
    try:
        await message.guild.ban(
            message.author,
            reason='Zero-tolerance: hate speech / discriminatory slur detected (automatic)',
            delete_message_days=1,
        )
    except (discord.Forbidden, discord.HTTPException):
        pass


