@bot.tree.command(name="completecontract", description="Complete an assigned contract")
@app_commands.describe(
    contract_id="Contract ID",
    flight_time="Flight time in hours",
    landing_rate="Landing rate in fpm (optional)",
)
async def completecontract(
    interaction: discord.Interaction,
    contract_id: int,
    flight_time: float,
    landing_rate: int = None,
):
    conn = get_db()
    pilot = conn.execute(
        "SELECT * FROM pilots WHERE user_id=? AND guild_id=?",
        (str(interaction.user.id), str(interaction.guild_id)),
    ).fetchone()
    if not pilot:
        conn.close()
        await interaction.response.send_message(
            "❌ You are not registered as a pilot.", ephemeral=True
        )
        return
    active = conn.execute(
        "SELECT * FROM active_contracts WHERE pilot_id=? AND guild_id=?",
        (str(interaction.user.id), str(interaction.guild_id)),
    ).fetchone()
    if not active or active["id"] != contract_id:
        conn.close()
        await interaction.response.send_message(
            f"❌ You do not have contract #{contract_id} active.", ephemeral=True
        )
        return
    new_hours = pilot["flight_hours"] + flight_time
    new_flights = pilot["flights"] + 1
    new_miles = pilot["miles"] + active["distance"]
    new_balance = pilot["balance"] + active["pay"]
    conn.execute(
        "UPDATE pilots SET flight_hours=?, flights=?, miles=?, balance=? WHERE user_id=? AND guild_id=?",
        (
            new_hours,
            new_flights,
            new_miles,
            new_balance,
            str(interaction.user.id),
            str(interaction.guild_id),
        ),
    )
