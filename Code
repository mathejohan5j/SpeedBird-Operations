# ─── VIRTUAL AIRLINE — LEADERBOARD ───────────────────────────────────────────


@bot.tree.command(name="leaderboard", description="View pilot leaderboards")
@app_commands.describe(category="Leaderboard category")
@app_commands.choices(
    category=[
        app_commands.Choice(name="Flight Hours", value="hours"),
        app_commands.Choice(name="Total Flights", value="flights"),
        app_commands.Choice(name="Miles Flown", value="miles"),
        app_commands.Choice(name="Earnings", value="balance"),
    ]
)
async def leaderboard(interaction: discord.Interaction, category: str = "hours"):
    column_map = {
        "hours": ("flight_hours", "Flight Hours", "🕐"),
        "flights": ("flights", "Total Flights", "✈️"),
        "miles": ("miles", "Miles Flown", "🗺️"),
        "balance": ("balance", "Earnings", "💰"),
    }
    col, label, emoji = column_map[category]
    conn = get_db()
    rows = conn.execute(
        f"SELECT * FROM pilots WHERE guild_id=? ORDER BY {col} DESC LIMIT 10",
        (str(interaction.guild_id),),
    ).fetchall()
    conn.close()
    embed = brand_embed(title=f'{emoji} Leaderboard — {label}')
    if not rows:
        embed.description = 'No pilots registered yet. Use `/register` to join!\n\n-# © British Airways Virtual PF. All rights reserved.'
    else:
        medals = ['🥇', '🥈', '🥉']
        lines = []
        for i, row in enumerate(rows):
            member = interaction.guild.get_member(int(row['user_id']))
            name = member.display_name if member else f'<@{row["user_id"]}>'
            icon = medals[i] if i < 3 else f'`#{i + 1}`'
            value = row[col]
            val_str = (
                f'{value:.1f}h'    if category == 'hours'
                else f'{value:,.0f} nm' if category == 'miles'
                else f'${value:,.0f}'   if category == 'balance'
                else str(int(value))
            )
            lines.append(f'> {icon} **{name}** — {val_str}')
        embed.description = '\n'.join(lines) + '\n\n-# © British Airways Virtual PF. All rights reserved.'
    await interaction.response.send_message(embed=embed, files=brand_files())


# ─── Error Handler ────────────────────────────────────────────────────────────


@bot.tree.error
async def on_app_command_error(
    interaction: discord.Interaction, error: app_commands.AppCommandError
):
    if isinstance(error, app_commands.MissingPermissions):
        await interaction.response.send_message(
            "❌ You do not have permission to use this command.", ephemeral=True
        )
    elif isinstance(error, app_commands.BotMissingPermissions):
        await interaction.response.send_message(
            "❌ I do not have the required permissions to do that.", ephemeral=True
        )
    else:
        await interaction.response.send_message(
            f"❌ An error occurred: {error}", ephemeral=True
        )


