@bot.tree.command(name="warn", description="Issue a warning to a user")
@app_commands.describe(user="The user to warn", reason="Reason for the warning")
@app_commands.checks.has_permissions(manage_messages=True)
async def warn(interaction: discord.Interaction, user: discord.Member, reason: str):
    conn = get_db()
    conn.execute(
        "INSERT INTO warnings (guild_id, user_id, moderator_id, reason, timestamp) VALUES (?, ?, ?, ?, ?)",
        (
            str(interaction.guild_id),
            str(user.id),
            str(interaction.user.id),
            reason,
            datetime.utcnow().isoformat(),
        ),
    )
    conn.commit()
    count = conn.execute(
        "SELECT COUNT(*) FROM warnings WHERE guild_id=? AND user_id=?",
        (str(interaction.guild_id), str(user.id)),
    ).fetchone()[0]
    conn.close()

    embed = brand_embed(title="User Warning <:warning:1495058284208722010>")
    embed.description = (
        f"> The user {user.mention} has received a warning. They now have a total of **{count}** warning(s).\n\n"
        f"Please be respectful to everyone in this server, we hate to discipline you and we trust you. "
        f"But we can all do better.\n\n"
        f"-# *If you have any further questions, we will be more than happy to answer them!*\n\n"
        f"-# © British Airways Virtual PF. All rights reserved."
