@bot.tree.command(name="acceptcontract", description="Accept a contract")
@app_commands.describe(contract_id="Contract ID")
async def acceptcontract(interaction: discord.Interaction, contract_id: int):
    conn = get_db()
    pilot = conn.execute(
        "SELECT 1 FROM pilots WHERE user_id=? AND guild_id=?",
        (str(interaction.user.id), str(interaction.guild_id)),
    ).fetchone()
    if not pilot:
        conn.close()
        await interaction.response.send_message(
            "❌ You need to `/register` as a pilot first.", ephemeral=True
        )
        return
    active = conn.execute(
        "SELECT 1 FROM active_contracts WHERE pilot_id=? AND guild_id=?",
        (str(interaction.user.id), str(interaction.guild_id)),
    ).fetchone()
    if active:
        conn.close()
        await interaction.response.send_message(
            "❌ You already have an active contract. Use `/completecontract` to finish it first.",
            ephemeral=True,
        )
        return
    c = next((x for x in CONTRACTS if x["id"] == contract_id), None)
    if not c:
        conn.close()
        await interaction.response.send_message(
            f"❌ Contract #{contract_id} not found.", ephemeral=True
        )
        return
    conn.execute(
        "INSERT INTO active_contracts (guild_id, pilot_id, departure, arrival, aircraft, distance, pay, difficulty, accepted_at) VALUES (?,?,?,?,?,?,?,?,?)",
        (
            str(interaction.guild_id),
            str(interaction.user.id),
            c["departure"],
            c["arrival"],
            c["aircraft"],
            c["distance"],
            c["pay"],
            c["difficulty"],
            datetime.utcnow().isoformat(),
        ),
    )
    conn.commit()
    conn.close()
    embed = brand_embed(title=f'✅ Contract #{contract_id} Accepted!')
