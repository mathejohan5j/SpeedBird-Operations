# ─── Slur Filter ──────────────────────────────────────────────────────────────

_LEET: dict = {
    ord('0'): 'o', ord('1'): 'i', ord('3'): 'e', ord('4'): 'a',
    ord('5'): 's', ord('6'): 'g', ord('7'): 't', ord('8'): 'b',
    ord('9'): 'g', ord('@'): 'a', ord('$'): 's', ord('!'): 'i',
    ord('+'): 't', ord('|'): 'i', ord('*'): '',
}

SLUR_LIST = [
    'nigger', 'nigga', 'faggot', 'kike', 'chink', 'spic', 'wetback',
    'beaner', 'gook', 'coon', 'sandnigger', 'towelhead', 'tranny',
]


def _normalize(text: str) -> str:
    text = text.lower().translate(_LEET)
    return re.sub(r'[^a-z]', '', text)


def _contains_slur(text: str) -> bool:
    clean = _normalize(text)
    return any(slur in clean for slur in SLUR_LIST)


