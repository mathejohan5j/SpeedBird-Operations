    # ─── REVIEW COMMAND ───────────────────────────────────────────────────────────

    @bot.tree.command(name="review", description="Submit a review for British Airways Virtual PF")
    @app_commands.describe(
        rating="Your rating out of 5 stars",
        review="Why do you like or dislike the airline?",
    )
    @app_commands.choices(rating=[
        app_commands.Choice(name=f"{STAR_EMOJI} 1 Star", value=1),
        app_commands.Choice(name=f"{STAR_EMOJI} {STAR_EMOJI} 2 Stars", value=2),
        app_commands.Choice(name=f"{STAR_EMOJI} {STAR_EMOJI} {STAR_EMOJI} 3 Stars", value=3),
        app_commands.Choice(name=f"{STAR_EMOJI} {STAR_EMOJI} {STAR_EMOJI} {STAR_EMOJI} 4 Stars", value=4),
        app_commands.Choice(name=f"{STAR_EMOJI} {STAR_EMOJI} {STAR_EMOJI} {STAR_EMOJI} {STAR_EMOJI} 5 Stars", value=5),
    ])
    async def review(interaction: discord.Interaction, rating: int, review: str) -> None:
        """Submit a review for British Airways Virtual PF."""
        await interaction.response.defer(ephemeral=True)

        # Validate input
        if not review or len(review.strip()) == 0:
            await interaction.followup.send(
                "❌ Please provide a review.", ephemeral=True
            )
            return

        if len(review) > 2000:
            await interaction.followup.send(
                "❌ Review is too long (max 2000 characters).", ephemeral=True
            )
            return

        # Get the review channel
        channel = interaction.guild.get_channel(REVIEW_CHANNEL_ID)
        if not channel:
            await interaction.followup.send(
                "❌ Review channel not found — please contact an admin.", ephemeral=True
            )
            return

        # Verify bot has permissions
        if not channel.permissions_for(interaction.guild.me).send_messages:
            await interaction.followup.send(
                "❌ I don't have permission to post in the review channel.", ephemeral=True
            )
            return

        try:
            # Create the review embed
            stars = STAR_EMOJI * rating
            embed = brand_embed(title="New Member Review")
            embed.description = (
                f"## {stars}\n\n"
                f"> {review}\n\n"
                f"-# © British Airways Virtual PF. All rights reserved."
            )
            embed.add_field(
                name="Reviewer",
                value=f"> {interaction.user.mention}",
                inline=True
            )
            embed.add_field(
                name="Rating",
                value=f"> {stars} ({rating}/5)",
                inline=True
            )
            embed.add_field(
                name="From",
                value=f"> {interaction.channel.mention}",
                inline=True
            )
            embed.set_footer(text=f"User ID: {interaction.user.id}")
            embed.timestamp = discord.utils.utcnow()

            # Send to review channel
            await channel.send(embed=embed, files=brand_files())

            # Confirm to user
            await interaction.followup.send(
                "✅ Your review has been submitted — thank you!", ephemeral=True
            )

        except discord.Forbidden:
            await interaction.followup.send(
                "❌ I don't have permission to post in the review channel.", ephemeral=True
            )
        except discord.HTTPException as e:
            await interaction.followup.send(
                f"❌ Failed to submit review: {str(e)}", ephemeral=True
            )
        except Exception as e:
            await interaction.followup.send(
                "❌ An unexpected error occurred. Please try again later.", ephemeral=True
            )
            print(f"Review command error: {e}")


