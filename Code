@bot.tree.command(name="warnings", description="View a user's warnings")
@app_commands.describe(user="The user to check")
@app_commands.checks.has_permissions(manage_messages=True)
async def warnings(interaction: discord.Interaction, user: discord.Member):
    conn = get_db()
    rows = conn.execute(
        "SELECT * FROM warnings WHERE guild_id=? AND user_id=? ORDER BY timestamp DESC",
        (str(interaction.guild_id), str(user.id)),
    ).fetchall()
    conn.close()
    embed = brand_embed(title="Warning History <:warning:1495058284208722010>")
    if not rows:
        embed.description = (
            f"> {user.mention} has a clean record — no warnings on file.\n\n"
            f"-# *Keep up the great behaviour!*\n\n"
            f"-# © British Airways Virtual PF. All rights reserved."
        )
    else:
        warning_lines = []
        for i, row in enumerate(rows, 1):
            mod = interaction.guild.get_member(int(row["moderator_id"]))
            mod_str = mod.mention if mod else f"<@{row['moderator_id']}>"
            warning_lines.append(
                f"> **Warning #{i}** — {row['timestamp'][:10]}\n"
                f"> Reason: {row['reason']} · By: {mod_str}"
            )
        embed.description = (
            f"> {user.mention} has **{len(rows)}** warning(s) on record.\n\n"
            + "\n\n".join(warning_lines)
            + f"\n\n-# *If you have any further questions, we will be more than happy to answer them!*\n\n"
            f"-# © British Airways Virtual PF. All rights reserved."
        )
    await interaction.response.send_message(embed=embed, files=brand_files())


